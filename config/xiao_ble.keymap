#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/mouse.h> // マウスキーの定義を読み込む


    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                /* 
                 * XIAO BLEのピン数に合わせた最小構成の例（1キーのみ）
                 * 動作確認用に、どこか1ボタンを「A」に設定
                 */
                &kp A
            >;
        };
    };
};
